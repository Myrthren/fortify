generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js models ──────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Fortify models ──────────────────────────────────────
enum Tier {
  FREE
  PRO
  ELITE
  APEX
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  discordId     String?   @unique
  tier          Tier      @default(FREE)
  xp            Int       @default(0)
  streak        Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  subscription       Subscription?
  brandVoices        BrandVoice[]
  watchTerms         WatchTerm[]
  competitors        Competitor[]
  generations        Generation[]
  profile            Profile?
  notificationPrefs  NotificationPrefs?
  dealPosts          DealPost[]
  pods               PodMember[]
}

model Profile {
  userId       String   @id
  niche        String?
  skills       String[]
  lookingFor   String[]
  canOffer     String[]
  socials      Json?
  reputation   Int      @default(0)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  paypalSubId   String    @unique
  tier          Tier
  status        String    // ACTIVE, CANCELLED, SUSPENDED, EXPIRED
  startedAt     DateTime  @default(now())
  cancelledAt   DateTime?
  nextBillingAt DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrandVoice {
  id           String   @id @default(cuid())
  userId       String
  name         String
  trainingData String   @db.Text
  systemPrompt String   @db.Text
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WatchTerm {
  id        String   @id @default(cuid())
  userId    String
  term      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Competitor {
  id          String    @id @default(cuid())
  userId      String
  name        String
  url         String
  notes       String?   @db.Text
  lastReport  Json?
  lastScanned DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model NotificationPrefs {
  userId            String  @id
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dmPaymentFailed   Boolean @default(true)
  dmWeeklyReport    Boolean @default(true)
  dmTrendAlerts     Boolean @default(true)
  dmCompetitorDone  Boolean @default(true)
  dmLimitWarning    Boolean @default(true)
  dmRenewalReminder Boolean @default(true)
  dmOnboarding      Boolean @default(true)
  dmMilestones      Boolean @default(true)
  dmMatchmaking     Boolean @default(true)
  dmOwnerNewSub     Boolean @default(true)
  dmOwnerChurn      Boolean @default(true)
}

model Generation {
  id        String   @id @default(cuid())
  userId    String
  type      String   // hook, caption, audit, voice, etc.
  input     String   @db.Text
  output    String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum DealType {
  HIRING
  COLLAB
  OPPORTUNITY
}

model DealPost {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String   @db.Text
  type        DealType
  budget      String?
  link        String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model Pod {
  id        String      @id @default(cuid())
  name      String
  createdAt DateTime    @default(now())
  members   PodMember[]
}

model PodMember {
  podId     String
  userId    String
  joinedAt  DateTime @default(now())
  pod       Pod      @relation(fields: [podId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([podId, userId])
}
